<IfModule mod_rewrite.c>
    Options +FollowSymLinks
    RewriteEngine On

    # Когда корень сайта в панели = корень Laravel (не public/), запросы /storage/*
    # иначе попадают в storage/framework|logs|... на диске. Перенаправляем в public/storage
    # (симлинк на storage/app/public), где лежат articles/ и др.

    RewriteRule ^storage/(framework|logs)(/|$) - [F,L]

    RewriteRule ^storage/(.*)$ public/storage/$1 [L]
</IfModule>
